{
  "name": "paperclipai",
  "version": "0.2.7",
  "description": "Squadron CLI — orchestrate AI agent teams to run a business (fork of Paperclip)",
  "type": "module",
  "bin": {
    "squadron": "./dist/index.js"
  },
  "keywords": [
    "squadron",
    "paperclip",
    "ai",
    "agents",
    "orchestration",
    "cli"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Nexlab-One/Squadron.git",
    "directory": "cli"
  },
  "homepage": "https://github.com/Nexlab-One/Squadron",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "node --input-type=module -e \"import esbuild from 'esbuild'; import config from './esbuild.config.mjs'; await esbuild.build(config); import fs from 'fs'; if (process.platform !== 'win32') fs.chmodSync('dist/index.js', 0o755);\"",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "@paperclipai/adapter-claude-local": "workspace:*",
    "@paperclipai/adapter-codex-local": "workspace:*",
    "@paperclipai/adapter-cursor-local": "workspace:*",
    "@paperclipai/adapter-gemini-local": "workspace:*",
    "@paperclipai/adapter-opencode-local": "workspace:*",
    "@paperclipai/adapter-pi-local": "workspace:*",
    "@paperclipai/adapter-openclaw-gateway": "workspace:*",
    "@paperclipai/adapter-utils": "workspace:*",
    "@paperclipai/db": "workspace:*",
    "@paperclipai/server": "workspace:*",
    "@paperclipai/shared": "workspace:*",
    "commander": "^14.0.3",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
